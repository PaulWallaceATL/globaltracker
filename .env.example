# Copy to .env.local and fill in your keys before live testing.
# Never commit .env.local.

# ACLED (OAuth — myACLED email + password)
# If the password contains $, wrap it in double quotes and escape: "pass\$word"
ACLED_EMAIL=
ACLED_PASSWORD=

# Optional legacy/manual Bearer token (expires ~24h)
# ACLED_API_KEY=

NASA_FIRMS_MAP_KEY=
AISSTREAM_IO_API_KEY=
NEWSAPI_ORG_API_KEY=
GNEWS_API_KEY=
NEWSDATA_IO_API_KEY=

# Supabase (entity graph, situations, bookmarks, history)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional paid enrichments (free fallbacks used when empty)
# Spelling must be TOMTOM (not TONTON) — Vercel key names are exact-match.
TOMTOM_API_KEY=
AVIATIONSTACK_API_KEY=

# Optional: protect POST /api/ingest. App works without it.
INGEST_SECRET=

# After adding keys in the Vercel dashboard, you MUST Redeploy.
# Sensitive vars hide their value after save — that is expected.
# Or sync from this file: ./scripts/push-env-to-vercel.sh
